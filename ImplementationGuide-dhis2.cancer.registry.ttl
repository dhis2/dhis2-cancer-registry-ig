         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-behaviour-observation> ;
         fhir:reference [ fhir:v "StructureDefinition/cr-behaviour-observation" ]
       ] ;
       fhir:name [ fhir:v "Behaviour" ] ;
       fhir:description [ fhir:v "ICD-O-3 behaviour code of the neoplasm: 0=benign, 1=uncertain, 2=in situ, 3=malignant (primary site). Corresponds to the CR - Behaviour data element in the DHIS2 Cancer Registry Tumor stage." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
