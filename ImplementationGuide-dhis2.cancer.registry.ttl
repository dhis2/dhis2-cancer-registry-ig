         fhir:reference [ fhir:v "CodeSystem/CRTopographyGroupCS" ]
       ] ;
       fhir:name [ fhir:v "CR - Topography Group" ] ;
       fhir:description [ fhir:v "Topography group codes used in the Multiple Primary Tester data quality check. Groups are derived from topography codes using the mapping logic defined in the CanReg5 DefaultMultiplePrimaryTester class. Group 80 indicates an unspecified topography. These groups determine whether tumours at different sites should be considered duplicate or multiple primaries." ] ;
