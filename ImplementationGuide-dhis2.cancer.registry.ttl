         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/Encounter/ExampleTumorEncounter> ;
         fhir:reference [ fhir:v "Encounter/ExampleTumorEncounter" ]
       ] ;
       fhir:name [ fhir:v "Example Tumor Encounter" ] ;
       fhir:description [ fhir:v "Encounter recording the Tumor stage event for primary breast carcinoma." ] ;
       fhir:example [
         a fhir:Canonical ;
         fhir:v "https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-tumor-encounter"^^xsd:anyURI ;
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-tumor-encounter>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
