       ] ;
       fhir:name [ fhir:v "Example Tumor Number" ] ;
       fhir:description [ fhir:v "Tumour number: 01 (first tumour registered for this patient)." ] ;
       fhir:example [
         a fhir:Canonical ;
         fhir:v "https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-tumor-number-observation"^^xsd:anyURI ;
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-tumor-number-observation>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Observation"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/Observation/ExampleVitalStatus> ;
         fhir:reference [ fhir:v "Observation/ExampleVitalStatus" ]
       ] ;
       fhir:name [ fhir:v "Example Vital Status" ] ;
       fhir:description [ fhir:v "Patient alive at 6-month follow-up." ] ;
       fhir:example [
         a fhir:Canonical ;
         fhir:v "https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-vital-status-observation"^^xsd:anyURI ;
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-vital-status-observation>
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/FollowUp> ;
         fhir:reference [ fhir:v "StructureDefinition/FollowUp" ]
       ] ;
       fhir:name [ fhir:v "Follow up" ] ;
       fhir:description [ fhir:v "Follow-up stage of the DHIS2 Cancer Registry tracker program. This repeatable stage records the follow-up status of the registered patient over time, capturing the date of last contact, the vital status, and, in cases where the status is death, the date of death. This stage is not associated with a specific tumor or source." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Questionnaire"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/Questionnaire/FollowUpQuestionnaire> ;
         fhir:reference [ fhir:v "Questionnaire/FollowUpQuestionnaire" ]
       ] ;
       fhir:name [ fhir:v "Follow up Questionnaire" ] ;
       fhir:description [ fhir:v "Questionnaire for the Follow-up stage of the DHIS2 Cancer Registry tracker program. Records the follow-up status of registered patients over time, capturing the date of last contact, vital status, and date of death when applicable. This stage is not associated with a specific tumor or source." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-followup-encounter> ;
         fhir:reference [ fhir:v "StructureDefinition/cr-followup-encounter" ]
       ] ;
       fhir:name [ fhir:v "Follow-up Encounter" ] ;
       fhir:description [ fhir:v "Encounter representing a single Follow-up stage event in the DHIS2 Cancer Registry tracker program. Each follow-up contact with a registered patient to ascertain vital status is recorded as a separate encounter. Observations within this encounter capture the vital status, date of last contact, and optional date of death." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-grade-observation> ;
         fhir:reference [ fhir:v "StructureDefinition/cr-grade-observation" ]
       ] ;
       fhir:name [ fhir:v "Histological Grade" ] ;
       fhir:description [ fhir:v "Histological grade (differentiation) of the tumour as defined in ICD-O-3. LOINC 33732-9. Grade codes: 1=well differentiated, 2=moderately differentiated, 3=poorly differentiated, 4=undifferentiated, 5–8=lymphomas/leukaemias, 9=not determined. Corresponds to the CR - Grade data element in the DHIS2 Cancer Registry Tumor stage." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-incidence-date-observation> ;
         fhir:reference [ fhir:v "StructureDefinition/cr-incidence-date-observation" ]
       ] ;
       fhir:name [ fhir:v "Incidence Date" ] ;
       fhir:description [ fhir:v "Date of incidence (diagnosis date) of the cancer case. Corresponds to the CR - Incidence date data element in the DHIS2 Cancer Registry Tumor stage." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-morphology-observation> ;
         fhir:reference [ fhir:v "StructureDefinition/cr-morphology-observation" ]
       ] ;
       fhir:name [ fhir:v "Morphology" ] ;
       fhir:description [ fhir:v "ICD-O-3 morphology code (4-digit histological type) of the neoplasm, e.g. 8500 = infiltrating duct carcinoma. Corresponds to the CR - Morphology data element in the DHIS2 Cancer Registry Tumor stage." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:extension"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-rare> ;
         fhir:reference [ fhir:v "StructureDefinition/cr-rare" ]
       ] ;
       fhir:name [ fhir:v "Rare Tumor Classification" ] ;
       fhir:description [ fhir:v "Indicates whether the registered tumor has been classified as rare according to the IARC/CanReg5 data quality checks. This is a computed flag derived from the topography-morphology combination evaluated against the IARC rare cancer reference tables. Corresponds to the CR - Rare data element in the DHIS2 Cancer Registry Tumor stage." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-site-observation> ;
         fhir:reference [ fhir:v "StructureDefinition/cr-site-observation" ]
       ] ;
       fhir:name [ fhir:v "Site" ] ;
       fhir:description [ fhir:v "Higher-level anatomical site grouping derived from the ICD-O-3 topography. Corresponds to the CR - Site data element in the DHIS2 Cancer Registry Tumor stage." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/Source> ;
         fhir:reference [ fhir:v "StructureDefinition/Source" ]
       ] ;
       fhir:name [ fhir:v "Source" ] ;
       fhir:description [ fhir:v "Source stage of the DHIS2 Cancer Registry tracker program. This repeatable stage records the documentation sources from which a cancer case has been notified to the registry. Each source represents a piece of documentation, such as a hospital record, pathology report, or death certificate, that supports the registration of a specific tumor. Sources are linked to a specific tumor via the Tumor Number." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-source-encounter> ;
         fhir:reference [ fhir:v "StructureDefinition/cr-source-encounter" ]
       ] ;
       fhir:name [ fhir:v "Source Notification Encounter" ] ;
       fhir:description [ fhir:v "Encounter representing a single Source stage event in the DHIS2 Cancer Registry tracker program. Each documentation source (hospital record, pathology report, death certificate, etc.) that notifies the registry about a cancer case is recorded as a separate encounter. Observations within this encounter capture the source type and linked tumor number." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Questionnaire"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/Questionnaire/SourceQuestionnaire> ;
         fhir:reference [ fhir:v "Questionnaire/SourceQuestionnaire" ]
       ] ;
       fhir:name [ fhir:v "Source Questionnaire" ] ;
       fhir:description [ fhir:v "Questionnaire for the Source stage of the DHIS2 Cancer Registry tracker program. Records the documentation sources from which a cancer case has been notified to the registry. Each source represents a piece of documentation (such as a hospital record, pathology report, or death certificate) linked to a specific tumor via the Tumor Number. Contains a visible Source section and a hidden TUMOURIDSOURCETABLE section used for CanReg5 data extraction." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-source-tumor-number-observation> ;
         fhir:reference [ fhir:v "StructureDefinition/cr-source-tumor-number-observation" ]
       ] ;
       fhir:name [ fhir:v "Source Tumor Number" ] ;
       fhir:description [ fhir:v "Tumor number that this source notification relates to. Links the source to a specific tumor within the patient's registration. Corresponds to the CR - Source: Tumor number data element in the DHIS2 Cancer Registry Source stage." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-source-type-observation> ;
         fhir:reference [ fhir:v "StructureDefinition/cr-source-type-observation" ]
       ] ;
       fhir:name [ fhir:v "Source Type" ] ;
       fhir:description [ fhir:v "Type of documentation source that notified the cancer registry about a case (e.g. hospital, laboratory, death certificate). Country-specific — must be localised. Corresponds to the CR - Source Type data element in the DHIS2 Cancer Registry Source stage." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-topography-observation> ;
         fhir:reference [ fhir:v "StructureDefinition/cr-topography-observation" ]
       ] ;
       fhir:name [ fhir:v "Topography" ] ;
       fhir:description [ fhir:v "ICD-O-3 topography code indicating the anatomical site of the primary tumour. Corresponds to the CR - Topography data element in the DHIS2 Cancer Registry Tumor stage." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:logical"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/Tumor> ;
         fhir:reference [ fhir:v "StructureDefinition/Tumor" ]
       ] ;
       fhir:name [ fhir:v "Tumor" ] ;
       fhir:description [ fhir:v "Tumor stage of the DHIS2 Cancer Registry tracker program. This repeatable stage is the central component capturing all key clinical and epidemiological information related to an individual cancer case." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-tumor-number-observation> ;
         fhir:reference [ fhir:v "StructureDefinition/cr-tumor-number-observation" ]
       ] ;
       fhir:name [ fhir:v "Tumor Number" ] ;
       fhir:description [ fhir:v "Sequential tumor number within the patient's registration (1–10). Corresponds to the CR - Tumor number data element in the DHIS2 Cancer Registry Tumor stage." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "Questionnaire"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/Questionnaire/TumorQuestionnaire> ;
         fhir:reference [ fhir:v "Questionnaire/TumorQuestionnaire" ]
       ] ;
       fhir:name [ fhir:v "Tumor Questionnaire" ] ;
       fhir:description [ fhir:v "Questionnaire for the Tumor stage of the DHIS2 Cancer Registry tracker program. This is the central data collection component, structured into sections: Patient (demographics and geographic information), Tumor (core variables aligned with CanReg5 ICD-O-3.2 standards including site, topography, morphology, behaviour, basis of diagnosis, and grade), Check Status (triggers for executing data quality checks), Checks (hidden section storing individual check results for rare/invalid classifications), Morphology Topography Check (hidden section for topography-morphology validation), Multiple Primary Tester (hidden section for duplicate/multiple primary determination), Rare Status (confirmation of flagged rare cases by authorised supervisors), and Tumor ID (hidden section supporting CanReg5 data extraction)." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-tumor-encounter> ;
         fhir:reference [ fhir:v "StructureDefinition/cr-tumor-encounter" ]
       ] ;
       fhir:name [ fhir:v "Tumor Registration Encounter" ] ;
       fhir:description [ fhir:v "Encounter representing a single Tumor stage event in the DHIS2 Cancer Registry tracker program. Each time a tumour is registered for a patient, a new Encounter of this type is created. Observations for each data element (topography, morphology, behaviour, grade, basis of diagnosis, etc.) reference this Encounter." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-vital-status-observation> ;
         fhir:reference [ fhir:v "StructureDefinition/cr-vital-status-observation" ]
       ] ;
       fhir:name [ fhir:v "Vital Status" ] ;
       fhir:description [ fhir:v "Follow-up vital status of the registered cancer patient (alive, dead, or unknown). Corresponds to the CR - Status data element in the DHIS2 Cancer Registry Follow-up stage." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] ) ;
     fhir:page [
       fhir:extension ( [
