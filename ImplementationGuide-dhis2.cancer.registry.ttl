       ] ;
       fhir:name [ fhir:v "CR - Site" ] ;
       fhir:description [ fhir:v "Anatomical site codes used to filter topography values in a dependent dropdown list. When a site is selected, only the topography codes valid for the chosen site are presented for selection, simplifying data entry for registry staff." ] ;
