       ] ;
       fhir:name [ fhir:v "Example Topography" ] ;
       fhir:description [ fhir:v "Topography observation: C50.4 — Upper-outer quadrant of breast." ] ;
       fhir:example [
         a fhir:Canonical ;
         fhir:v "https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-topography-observation"^^xsd:anyURI ;
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-topography-observation>
       ]
     ] [
