     fhir:resource ( [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-address-observation> ;
         fhir:reference [ fhir:v "StructureDefinition/cr-address-observation" ]
       ] ;
       fhir:name [ fhir:v "Address" ] ;
       fhir:description [ fhir:v "Administrative address code of the patient at incidence. Country-specific — must be localised. Corresponds to the CR - Address data element in the DHIS2 Cancer Registry Tumor stage." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
           fhir:l <http://hl7.org/fhir/tools/StructureDefinition/resource-information>
         ] ;
