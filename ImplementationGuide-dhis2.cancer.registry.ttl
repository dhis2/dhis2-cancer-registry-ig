         ] ;
         fhir:value [
           a fhir:String ;
           fhir:v "StructureDefinition:resource"
         ]
       ] ) ;
       fhir:reference [
         fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-cancer-registration-episode> ;
         fhir:reference [ fhir:v "StructureDefinition/cr-cancer-registration-episode" ]
       ] ;
       fhir:name [ fhir:v "Cancer Registration EpisodeOfCare" ] ;
       fhir:description [ fhir:v "Episode of Care representing the overall enrollment of a patient in the cancer registry. Corresponds to the DHIS2 Cancer Registry tracker program enrollment. All stage-level Encounters (Tumor, Source, Follow-up) reference this episode." ] ;
       fhir:example [
         a fhir:Boolean ;
         fhir:v false
       ]
     ] [
       fhir:extension ( [
         fhir:url [
           fhir:v "http://hl7.org/fhir/tools/StructureDefinition/resource-information"^^xsd:anyURI ;
