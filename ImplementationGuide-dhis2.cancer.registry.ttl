  ] ; # 
  fhir:version [ fhir:v "0.1.0"] ; # 
  fhir:name [ fhir:v "DHIS2CancerRegistryIG"] ; # 
  fhir:title [ fhir:v "DHIS2 Cancer Registry Implementation Guide"] ; # 
