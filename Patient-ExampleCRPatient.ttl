# - resource -------------------------------------------------------------------

<https://dhis2.org/fhir/cancer-registry/Patient/ExampleCRPatient> a fhir:Patient ;
  fhir:nodeRole fhir:treeRoot ;
  fhir:id [ fhir:v "ExampleCRPatient"] ; # 
  fhir:meta [
     fhir:profile ( [
       fhir:v "https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-patient"^^xsd:anyURI ;
       fhir:l <https://dhis2.org/fhir/cancer-registry/StructureDefinition/cr-patient>
     ] )
  ] ; # 
  fhir:text [
     fhir:status [ fhir:v "generated" ] ;
     fhir:div [ fhir:v "<div xmlns=\"http://www.w3.org/1999/xhtml\"><p class=\"res-header-id\"><b>Generated Narrative: Patient ExampleCRPatient</b></p><a name=\"ExampleCRPatient\"> </a><a name=\"hcExampleCRPatient\"> </a><div style=\"display: inline-block; background-color: #d9e0e7; padding: 6px; margin: 4px; border: 1px solid #8da1b4; border-radius: 5px; line-height: 60%\"><p style=\"margin-bottom: 0px\"/><p style=\"margin-bottom: 0px\">Profile: <a href=\"StructureDefinition-cr-patient.html\">Cancer Registry Patient</a></p></div><p style=\"border: 1px #661aff solid; background-color: #e6e6ff; padding: 10px;\">Jane Doe  Female, DoB: 1970-03-15 ( Medical record number)</p><hr/></div>"^^rdf:XMLLiteral ]
  ] ; # 
  fhir:identifier ( [
     fhir:type [
       fhir:coding ( [
         fhir:system [
           fhir:v "http://terminology.hl7.org/CodeSystem/v2-0203"^^xsd:anyURI ;
           fhir:l <http://terminology.hl7.org/CodeSystem/v2-0203>
         ] ;
         fhir:code [ fhir:v "MR" ]
       ] )
     ] ;
     fhir:system [
       fhir:v "https://dhis2.org/fhir/cancer-registry/regno"^^xsd:anyURI ;
       fhir:l <https://dhis2.org/fhir/cancer-registry/regno>
     ] ;
     fhir:value [ fhir:v "20240001" ]
  ] ) ; # 
  fhir:name ( [
     fhir:family [ fhir:v "Doe" ] ;
     fhir:given ( [ fhir:v "Jane" ] )
  ] ) ; # 
  fhir:gender [ fhir:v "female"] ; # 
  fhir:birthDate [ fhir:v "1970-03-15"^^xsd:date] . # 

