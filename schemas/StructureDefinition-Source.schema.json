{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "http://smart.who.int/base/StructureDefinition-Source.schema.json",
  "title": "Source",
  "description": "Source stage of the DHIS2 Cancer Registry tracker program. This repeatable stage records the documentation sources from which a cancer case has been notified to the registry. Each source represents a piece of documentation, such as a hospital record, pathology report, or death certificate, that supports the registration of a specific tumor. Sources are linked to a specific tumor via the Tumor Number.",
  "type": "object",
  "properties": {
    "resourceType": {
      "type": "string",
      "const": "Source",
      "description": "Resource type identifier for Source logical model"
    },
    "@context": {
      "description": "JSON-LD context for this logical model with ValueSet vocabularies",
      "anyOf": [
        {
          "type": "string",
          "format": "uri",
          "description": "URI reference to external JSON-LD context"
        },
        {
          "type": "object",
          "description": "Inline JSON-LD context",
          "properties": {
            "@version": {
              "type": "number",
              "const": 1.1
            },
            "fhir": {
              "type": "string",
              "const": "http://hl7.org/fhir/"
            }
          },
          "additionalProperties": {
            "type": "string",
            "format": "uri"
          }
        },
        {
          "type": "array",
          "description": "Array of JSON-LD context objects/URIs",
          "items": {
            "anyOf": [
              {
                "type": "string",
                "format": "uri"
              },
              {
                "type": "object"
              }
            ]
          }
        }
      ]
    },
    "@type": {
      "type": "string",
      "description": "JSON-LD type identifier for Source logical model",
      "examples": [
        "LogicalModel-Source"
      ]
    },
    "crSourceTumorNumber": {
      "oneOf": [
        {
          "type": "string",
          "description": "Code from ValueSet CRTumorNumberVS (plain string)"
        },
        {
          "type": "object",
          "description": "Code from ValueSet CRTumorNumberVS (JSON-LD structure)",
          "properties": {
            "@type": {
              "type": "string",
              "const": "http://smart.who.int/base/ValueSet-CRTumorNumberVS.jsonld",
              "description": "JSON-LD type reference to ValueSet CRTumorNumberVS"
            },
            "@id": {
              "type": "string",
              "format": "uri",
              "description": "Full IRI of the code from ValueSet CRTumorNumberVS"
            }
          },
          "required": [
            "@type",
            "@id"
          ],
          "additionalProperties": false
        }
      ],
      "description": "CR - Source: Tumor number"
    },
    "crSourceDate": {
      "type": "string",
      "format": "date",
      "description": "CR - Source date"
    },
    "crSourceType": {
      "oneOf": [
        {
          "type": "string",
          "description": "Code from ValueSet CRPlaceholderSourceTypeVS (plain string)"
        },
        {
          "type": "object",
          "description": "Code from ValueSet CRPlaceholderSourceTypeVS (JSON-LD structure)",
          "properties": {
            "@type": {
              "type": "string",
              "const": "http://smart.who.int/base/ValueSet-CRPlaceholderSourceTypeVS.jsonld",
              "description": "JSON-LD type reference to ValueSet CRPlaceholderSourceTypeVS"
            },
            "@id": {
              "type": "string",
              "format": "uri",
              "description": "Full IRI of the code from ValueSet CRPlaceholderSourceTypeVS"
            }
          },
          "required": [
            "@type",
            "@id"
          ],
          "additionalProperties": false
        }
      ],
      "description": "CR - Source Type"
    },
    "crPatientId": {
      "type": "string",
      "description": "CR - Patient ID"
    },
    "crTumouridsourcetable": {
      "type": "string",
      "description": "CR - TUMOURIDSOURCETABLE"
    }
  },
  "required": [
    "resourceType",
    "crSourceTumorNumber"
  ],
  "resourceDefinition": "https://dhis2.org/fhir/cancer-registry/StructureDefinition/Source",
  "fhir:parent": "http://hl7.org/fhir/StructureDefinition/Base",
  "jsonld:valuesets": [
    "CRTumorNumberVS",
    "CRPlaceholderSourceTypeVS"
  ],
  "jsonld:contextTemplate": {
    "@version": 1.1,
    "fhir": "http://hl7.org/fhir/",
    "CRTumorNumberVS": "http://smart.who.int/base/ValueSet-CRTumorNumberVS.jsonld",
    "CRPlaceholderSourceTypeVS": "http://smart.who.int/base/ValueSet-CRPlaceholderSourceTypeVS.jsonld"
  }
}